# Copy to .env.local and fill in your key.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (defaults to claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# Optional: pin the analytics "as of" date (ISO yyyy-mm-dd). Defaults to the
# seed dataset anchor so the demo stays deterministic. See src/lib/clock.ts.
# PROCUREMENT_AS_OF_DATE=2025-06-26
